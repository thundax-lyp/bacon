# Database
BACON_DB_URL=jdbc:mysql://127.0.0.1:3306/bacon_sample?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
BACON_DB_USERNAME=root
BACON_DB_PASSWORD=change_me
BACON_DB_DRIVER=com.mysql.cj.jdbc.Driver

# Runtime mode
BACON_RUNTIME_MODE=mono

# Repository mode
BACON_INVENTORY_REPOSITORY_MODE=strict
BACON_ORDER_REPOSITORY_MODE=strict
BACON_ORDER_OUTBOX_RETRY_ENABLED=true
