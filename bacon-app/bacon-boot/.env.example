BACON_SERVER_PORT=8080

BACON_MQ_ENABLED=true
BACON_MQ_TYPE=ROCKETMQ
BACON_ROCKETMQ_NAME_SERVER=127.0.0.1:9876
BACON_ROCKETMQ_PRODUCER_GROUP=bacon-boot-producer

BACON_DB_URL=jdbc:mysql://127.0.0.1:3306/bacon_demo?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
BACON_DB_USERNAME=example_user
BACON_DB_PASSWORD=example_password
BACON_DB_DRIVER=com.mysql.cj.jdbc.Driver

BACON_REDIS_HOST=127.0.0.1
BACON_REDIS_PORT=6379
BACON_REDIS_DATABASE=0
BACON_REDIS_PASSWORD=example_redis_password
BACON_REDIS_TIMEOUT=5s
