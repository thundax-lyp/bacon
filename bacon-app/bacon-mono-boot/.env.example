BACON_SERVER_PORT=8080

BACON_DB_URL=jdbc:mysql://127.0.0.1:3306/bacon_demo?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
BACON_DB_USERNAME=example_user
BACON_DB_PASSWORD=example_password
BACON_DB_DRIVER=com.mysql.cj.jdbc.Driver

BACON_REDIS_HOST=127.0.0.1
BACON_REDIS_PORT=6379
BACON_REDIS_DATABASE=0
BACON_REDIS_PASSWORD=example_redis_password
BACON_REDIS_TIMEOUT=5s

BACON_MQ_ENABLED=true
BACON_MQ_TYPE=ROCKETMQ
BACON_ROCKETMQ_NAME_SERVER=127.0.0.1:9876
BACON_ROCKETMQ_PRODUCER_GROUP=bacon-mono-boot-producer
BACON_INVENTORY_REPOSITORY_MODE=strict
BACON_INVENTORY_RETRY_MAX_ATTEMPTS=3
BACON_INVENTORY_RETRY_INITIAL_BACKOFF_MS=20
BACON_INVENTORY_RETRY_MAX_BACKOFF_MS=200
BACON_INVENTORY_AUDIT_RETRY_ENABLED=true
BACON_INVENTORY_AUDIT_RETRY_FIXED_DELAY_MS=10000
BACON_INVENTORY_AUDIT_RETRY_BATCH_SIZE=100
BACON_INVENTORY_AUDIT_RETRY_MAX_RETRIES=6
BACON_INVENTORY_AUDIT_RETRY_BASE_DELAY_SECONDS=30
BACON_INVENTORY_AUDIT_RETRY_MAX_DELAY_SECONDS=1800
BACON_INVENTORY_AUDIT_RETRY_LEASE_SECONDS=60

BACON_TINYID_SERVER=127.0.0.1:9999
BACON_TINYID_TOKEN=tinyid_token
BACON_TINYID_CONNECT_TIMEOUT=5s
BACON_TINYID_READ_TIMEOUT=5s
BACON_ID_SNOWFLAKE_WORKER_ID=1
BACON_ID_SNOWFLAKE_DATACENTER_ID=1
